# ─────────────────────────────────────────────────────────────
# VAJRA POWERBANK — Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────

# Site URL (e.g. https://vajrapowerbank.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── BRAND ────────────────────────────────────────────────────
BRAND_NAME=Vajra PowerBank

# ─── EMAIL / GMAIL SMTP ───────────────────────────────────────
# The Gmail that RECEIVES order notifications
BUSINESS_EMAIL=kritagyabhandari1999@gmail.com

# The Gmail you use to SEND emails (must match SMTP_USER)
EMAIL_FROM=kritagyabhandari1999@gmail.com

# Gmail SMTP settings (use Gmail App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=kritagyabhandari1999@gmail.com
SMTP_PASS=your_gmail_app_password_here

# ─── GOOGLE SPREADSHEET ───────────────────────────────────────
# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID_HERE/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# The tab name in your Google Sheet (default: Orders)
GOOGLE_SHEET_TAB_NAME=Orders

# From your Google Service Account JSON key file
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# The private_key from your service account JSON (keep the quotes)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── FRONTEND URL (for CORS if needed) ────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── EMAIL SERVICE API KEY (optional, if using Resend/SendGrid) ──
EMAIL_SERVICE_API_KEY=
